{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.script-to-shootable-storyboard.invalid/v1/beat-sheet.schema.json",
  "title": "Beat Sheet",
  "description": "按行动、信息或权力关系变化拆分剧情节拍，并保持与来源事实的多对多映射。",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "created_by_stage",
    "source_hash",
    "beat_sheet_id",
    "job_id",
    "scene_ids",
    "beats",
    "abstract_resolutions",
    "field_provenance"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/semver"
    },
    "created_at": {
      "$ref": "#/$defs/dateTime"
    },
    "created_by_stage": {
      "$ref": "#/$defs/stageId"
    },
    "source_hash": {
      "$ref": "#/$defs/hash"
    },
    "beat_sheet_id": {
      "$ref": "#/$defs/id"
    },
    "job_id": {
      "$ref": "#/$defs/id"
    },
    "scene_ids": {
      "$ref": "#/$defs/idList"
    },
    "beats": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/beat"
      },
      "minItems": 1
    },
    "abstract_resolutions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/abstractResolution"
      }
    },
    "field_provenance": {
      "$ref": "#/$defs/fieldProvenance"
    }
  },
  "$defs": {
    "id": {
      "$ref": "provenance.schema.json#/$defs/artifactId"
    },
    "semver": {
      "$ref": "provenance.schema.json#/$defs/semver"
    },
    "dateTime": {
      "$ref": "provenance.schema.json#/$defs/dateTime"
    },
    "stageId": {
      "$ref": "provenance.schema.json#/$defs/stageId"
    },
    "hash": {
      "$ref": "provenance.schema.json#/$defs/hash"
    },
    "sourceSpan": {
      "$ref": "provenance.schema.json#/$defs/sourceSpan"
    },
    "fieldProvenance": {
      "$ref": "provenance.schema.json#/$defs/fieldProvenance"
    },
    "idList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "abstractResolution": {
      "type": "object",
      "required": [
        "abstract_resolution_id",
        "source_span",
        "abstract_text",
        "resolution_type",
        "evidence_description",
        "target_beat_ids"
      ],
      "properties": {
        "abstract_resolution_id": {
          "$ref": "#/$defs/id"
        },
        "source_span": {
          "$ref": "#/$defs/sourceSpan"
        },
        "abstract_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        },
        "resolution_type": {
          "type": "string",
          "enum": [
            "body_action",
            "prop_state_change",
            "spatial_change",
            "facial_or_hand_action",
            "environment_reaction",
            "audible_evidence",
            "necessary_dialogue"
          ]
        },
        "evidence_description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        },
        "target_beat_ids": {
          "$ref": "#/$defs/idList"
        },
        "target_shot_ids": {
          "$ref": "#/$defs/idList"
        },
        "audio_event_ids": {
          "$ref": "#/$defs/idList"
        }
      },
      "unevaluatedProperties": false
    },
    "beat": {
      "type": "object",
      "required": [
        "beat_id",
        "scene_id",
        "sequence",
        "source_spans",
        "source_text",
        "visible_event",
        "information_before",
        "information_after",
        "character_goal",
        "obstacle",
        "result",
        "must_preserve",
        "fact_ids",
        "field_provenance"
      ],
      "properties": {
        "beat_id": {
          "$ref": "#/$defs/id"
        },
        "scene_id": {
          "$ref": "#/$defs/id"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "source_spans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceSpan"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_text": {
          "type": "string",
          "minLength": 1
        },
        "participant_character_ids": {
          "$ref": "#/$defs/idList"
        },
        "visible_event": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "information_before": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        },
        "information_after": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        },
        "character_goal": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "obstacle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "result": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        },
        "start_state": {
          "type": "string",
          "maxLength": 1500
        },
        "end_state": {
          "type": "string",
          "maxLength": 1500
        },
        "must_preserve": {
          "type": "boolean"
        },
        "optional_visualization": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "uniqueItems": true
        },
        "cause_beat_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "effect_beat_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "coverage_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "hook_contract_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "fact_ids": {
          "$ref": "#/$defs/idList"
        },
        "authorized_addition": {
          "type": "boolean",
          "default": false
        },
        "authorization_id": {
          "$ref": "#/$defs/id"
        },
        "field_provenance": {
          "$ref": "#/$defs/fieldProvenance"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "authorized_addition": {
                "const": true
              }
            },
            "required": [
              "authorized_addition"
            ]
          },
          "then": {
            "required": [
              "authorization_id"
            ]
          }
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "unevaluatedProperties": false
}
