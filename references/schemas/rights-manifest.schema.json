{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.script-to-shootable-storyboard.invalid/v1/rights-manifest.schema.json",
  "title": "Rights, Consent, Privacy and Compliance Manifest",
  "description": "记录剧本、表演、声音、肖像、场地、音乐、素材、商标、模型输出及相关个人数据的权利证据、使用限制、隐私控制、继承和最严格约束合并结果。",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "created_by_stage",
    "source_hash",
    "rights_manifest_id",
    "job_id",
    "manifest_version",
    "target_regions",
    "target_platform_profile_ids",
    "rights_records",
    "inheritance_links",
    "effective_rights",
    "privacy_governance",
    "compliance_checks",
    "overall_status",
    "blocking_issue_ids",
    "field_provenance"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/semver" },
    "created_at": { "$ref": "#/$defs/dateTime" },
    "created_by_stage": { "$ref": "#/$defs/stageId" },
    "source_hash": { "$ref": "#/$defs/hash" },
    "rights_manifest_id": { "$ref": "#/$defs/id" },
    "job_id": { "$ref": "#/$defs/id" },
    "manifest_version": { "$ref": "#/$defs/semver" },
    "target_regions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "target_platform_profile_ids": { "$ref": "#/$defs/idList" },
    "rights_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/rightsRecord" },
      "minItems": 1
    },
    "inheritance_links": {
      "type": "array",
      "items": { "$ref": "#/$defs/inheritanceLink" }
    },
    "effective_rights": {
      "type": "array",
      "items": { "$ref": "#/$defs/effectiveRights" }
    },
    "privacy_governance": {
      "$ref": "#/$defs/privacyGovernance"
    },
    "compliance_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/complianceCheck" },
      "minItems": 1
    },
    "overall_status": {
      "type": "string",
      "enum": ["cleared", "conditional", "pending", "blocked"]
    },
    "blocking_issue_ids": { "$ref": "#/$defs/idList" },
    "verified_by": { "$ref": "#/$defs/idList" },
    "verified_at": { "$ref": "#/$defs/dateTime" },
    "field_provenance": { "$ref": "#/$defs/fieldProvenance" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "overall_status": { "const": "cleared" } },
        "required": ["overall_status"]
      },
      "then": {
        "required": ["verified_by", "verified_at"],
        "properties": {
          "blocking_issue_ids": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "overall_status": { "const": "blocked" } },
        "required": ["overall_status"]
      },
      "then": {
        "properties": {
          "blocking_issue_ids": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "id": { "$ref": "provenance.schema.json#/$defs/artifactId" },
    "semver": { "$ref": "provenance.schema.json#/$defs/semver" },
    "dateTime": { "$ref": "provenance.schema.json#/$defs/dateTime" },
    "stageId": { "$ref": "provenance.schema.json#/$defs/stageId" },
    "hash": { "$ref": "provenance.schema.json#/$defs/hash" },
    "fieldProvenance": { "$ref": "provenance.schema.json#/$defs/fieldProvenance" },
    "idList": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "permission": {
      "type": "string",
      "enum": ["allowed", "conditional", "forbidden", "unknown"]
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_id",
        "evidence_type",
        "locator",
        "evidence_hash",
        "issuer_or_signatory",
        "issued_at",
        "verification_status"
      ],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/id" },
        "evidence_type": {
          "type": "string",
          "enum": [
            "license",
            "contract",
            "release",
            "consent",
            "guardian_consent",
            "location_permit",
            "platform_terms",
            "policy",
            "public_domain_record",
            "provenance_credential",
            "other"
          ]
        },
        "locator": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "evidence_hash": { "$ref": "#/$defs/hash" },
        "issuer_or_signatory": { "type": "string", "minLength": 1, "maxLength": 300 },
        "issued_at": { "$ref": "#/$defs/dateTime" },
        "expires_at": { "$ref": "#/$defs/dateTime" },
        "verification_status": { "type": "string", "enum": ["verified", "pending", "rejected", "expired"] },
        "verified_by": { "$ref": "#/$defs/id" },
        "verified_at": { "$ref": "#/$defs/dateTime" }
      },
      "unevaluatedProperties": false
    },
    "rightsRecord": {
      "type": "object",
      "required": [
        "rights_record_id",
        "rights_subject_id",
        "subject_type",
        "subject_name",
        "related_entity_ids",
        "source",
        "owner_or_controller",
        "license_or_basis",
        "permissions",
        "territories",
        "attribution",
        "consent",
        "evidence",
        "verification_status",
        "privacy_flags",
        "field_provenance"
      ],
      "properties": {
        "rights_record_id": { "$ref": "#/$defs/id" },
        "rights_subject_id": { "$ref": "#/$defs/id" },
        "subject_type": {
          "type": "string",
          "enum": [
            "script",
            "adaptation",
            "performance",
            "voice",
            "likeness",
            "digital_replica",
            "location",
            "music_composition",
            "sound_recording",
            "sound_effect",
            "image",
            "video",
            "font",
            "trademark",
            "model_output",
            "personal_data",
            "biometric_data",
            "real_event",
            "public_figure",
            "other"
          ]
        },
        "subject_name": { "type": "string", "minLength": 1, "maxLength": 300 },
        "related_entity_ids": { "$ref": "#/$defs/idList" },
        "source": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "owner_or_controller": { "type": "string", "minLength": 1, "maxLength": 300 },
        "license_or_basis": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "permissions": {
          "type": "object",
          "required": [
            "commercial_use",
            "derivative_use",
            "ai_training_use",
            "ai_reference_use",
            "ai_generated_derivative_use",
            "distribution",
            "sublicensing"
          ],
          "properties": {
            "commercial_use": { "$ref": "#/$defs/permission" },
            "derivative_use": { "$ref": "#/$defs/permission" },
            "ai_training_use": { "$ref": "#/$defs/permission" },
            "ai_reference_use": { "$ref": "#/$defs/permission" },
            "ai_generated_derivative_use": { "$ref": "#/$defs/permission" },
            "distribution": { "$ref": "#/$defs/permission" },
            "sublicensing": { "$ref": "#/$defs/permission" },
            "conditions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
            }
          },
          "unevaluatedProperties": false
        },
        "territories": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(?:WORLDWIDE|[A-Z]{2})$" },
          "minItems": 1,
          "uniqueItems": true
        },
        "effective_at": { "$ref": "#/$defs/dateTime" },
        "expires_at": { "$ref": "#/$defs/dateTime" },
        "attribution": {
          "type": "object",
          "required": ["required", "credit_texts"],
          "properties": {
            "required": { "type": "boolean" },
            "credit_texts": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 500 }
            },
            "placement_rules": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 500 }
            }
          },
          "unevaluatedProperties": false
        },
        "consent": {
          "type": "object",
          "required": ["required", "status", "withdrawal_supported"],
          "properties": {
            "required": { "type": "boolean" },
            "status": { "type": "string", "enum": ["not_required", "obtained", "pending", "withdrawn", "expired", "unknown"] },
            "guardian_required": { "type": "boolean" },
            "guardian_consent_status": {
              "type": "string",
              "enum": ["not_required", "obtained", "pending", "withdrawn", "expired", "unknown"]
            },
            "withdrawal_supported": { "type": "boolean" },
            "withdrawal_deadline_days": { "type": "integer", "minimum": 0 }
          },
          "unevaluatedProperties": false
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "minItems": 1
        },
        "verification_status": {
          "type": "string",
          "enum": ["verified", "conditional", "pending", "rejected", "expired", "unknown"]
        },
        "privacy_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "personal_data",
              "biometric_data",
              "minor",
              "sensitive_data",
              "public_figure",
              "location_data",
              "voiceprint",
              "face_embedding",
              "none"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "platform_terms_version": { "type": "string", "maxLength": 120 },
        "regional_rule_version": { "type": "string", "maxLength": 120 },
        "field_provenance": { "$ref": "#/$defs/fieldProvenance" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "consent": {
                "properties": { "required": { "const": true } },
                "required": ["required"]
              }
            },
            "required": ["consent"]
          },
          "then": {
            "properties": {
              "consent": {
                "properties": {
                  "status": { "enum": ["obtained", "pending", "withdrawn", "expired", "unknown"] }
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "inheritanceLink": {
      "type": "object",
      "required": [
        "inheritance_link_id",
        "upstream_rights_record_ids",
        "downstream_entity_type",
        "downstream_entity_id",
        "merge_policy",
        "computed_at"
      ],
      "properties": {
        "inheritance_link_id": { "$ref": "#/$defs/id" },
        "upstream_rights_record_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "downstream_entity_type": {
          "type": "string",
          "enum": [
            "generation_task",
            "generation_attempt",
            "take",
            "media_asset",
            "composite_recipe",
            "timeline_clip",
            "final_export"
          ]
        },
        "downstream_entity_id": { "$ref": "#/$defs/id" },
        "merge_policy": { "const": "most_restrictive" },
        "computed_at": { "$ref": "#/$defs/dateTime" },
        "computation_hash": { "$ref": "#/$defs/hash" }
      },
      "unevaluatedProperties": false
    },
    "effectiveRights": {
      "type": "object",
      "required": [
        "effective_rights_id",
        "entity_type",
        "entity_id",
        "source_rights_record_ids",
        "territories",
        "earliest_expiry",
        "permissions",
        "required_attributions",
        "withdrawal_deadline_days",
        "status",
        "computed_at",
        "computation_hash"
      ],
      "properties": {
        "effective_rights_id": { "$ref": "#/$defs/id" },
        "entity_type": { "type": "string", "minLength": 1, "maxLength": 100 },
        "entity_id": { "$ref": "#/$defs/id" },
        "source_rights_record_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "territories": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(?:WORLDWIDE|[A-Z]{2})$" },
          "uniqueItems": true
        },
        "earliest_expiry": {
          "oneOf": [
            { "$ref": "#/$defs/dateTime" },
            { "type": "null" }
          ]
        },
        "permissions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/permission" }
        },
        "required_attributions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 500 },
          "uniqueItems": true
        },
        "withdrawal_deadline_days": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "status": { "type": "string", "enum": ["cleared", "conditional", "pending", "blocked"] },
        "computed_at": { "$ref": "#/$defs/dateTime" },
        "computation_hash": { "$ref": "#/$defs/hash" }
      },
      "unevaluatedProperties": false
    },
    "privacyGovernance": {
      "type": "object",
      "required": [
        "purpose_limitation",
        "lawful_basis",
        "storage_regions",
        "retention_days",
        "access_control",
        "withdrawal_process",
        "deletion_sla_days",
        "security_controls",
        "data_subject_request_process"
      ],
      "properties": {
        "purpose_limitation": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 500 },
          "minItems": 1
        },
        "lawful_basis": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 200 },
          "minItems": 1,
          "uniqueItems": true
        },
        "storage_regions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 100 },
          "minItems": 1,
          "uniqueItems": true
        },
        "retention_days": { "type": "integer", "minimum": 0 },
        "access_control": {
          "type": "object",
          "required": ["policy_id", "allowed_role_ids", "audit_logging"],
          "properties": {
            "policy_id": { "$ref": "#/$defs/id" },
            "allowed_role_ids": { "$ref": "#/$defs/idList" },
            "audit_logging": { "type": "boolean" }
          },
          "unevaluatedProperties": false
        },
        "withdrawal_process": { "type": "string", "minLength": 1, "maxLength": 1500 },
        "deletion_sla_days": { "type": "integer", "minimum": 0 },
        "security_controls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 500 },
          "minItems": 1
        },
        "data_subject_request_process": { "type": "string", "minLength": 1, "maxLength": 1500 },
        "cross_border_transfer_basis": { "type": "string", "maxLength": 1000 }
      },
      "unevaluatedProperties": false
    },
    "complianceCheck": {
      "type": "object",
      "required": [
        "check_id",
        "region",
        "platform_profile_id",
        "rule_name",
        "rule_version",
        "evidence_ids",
        "status",
        "severity"
      ],
      "properties": {
        "check_id": { "$ref": "#/$defs/id" },
        "region": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "platform_profile_id": { "$ref": "#/$defs/id" },
        "rule_name": { "type": "string", "minLength": 1, "maxLength": 300 },
        "rule_version": { "type": "string", "minLength": 1, "maxLength": 120 },
        "evidence_ids": { "$ref": "#/$defs/idList" },
        "status": { "type": "string", "enum": ["pass", "fail", "manual_review", "not_applicable"] },
        "severity": {
          "type": "string",
          "enum": ["blocker", "critical", "error", "warning", "info"]
        },
        "issue_id": { "$ref": "#/$defs/id" }
      },
      "unevaluatedProperties": false
    }
  },
  "unevaluatedProperties": false
}
