{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.script-to-shootable-storyboard.invalid/v1/provenance.schema.json",
  "title": "Field Provenance Bundle",
  "description": "字段级来源追踪。每个键使用 JSON Pointer 指向承载叙事信息的字段。",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "created_by_stage",
    "source_hash",
    "artifact_id",
    "field_provenance"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/semver"
    },
    "created_at": {
      "$ref": "#/$defs/dateTime"
    },
    "created_by_stage": {
      "$ref": "#/$defs/stageId"
    },
    "source_hash": {
      "$ref": "#/$defs/hash"
    },
    "artifact_id": {
      "$ref": "#/$defs/artifactId"
    },
    "field_provenance": {
      "$ref": "#/$defs/fieldProvenance"
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "hash": {
      "type": "string",
      "pattern": "^(?:sha256:)?[A-Fa-f0-9]{64}$"
    },
    "artifactId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[A-Za-z][A-Za-z0-9]*(?:[-_.:][A-Za-z0-9]+)*$"
    },
    "stageId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$"
    },
    "jsonPointer": {
      "type": "string",
      "pattern": "^/(?:[^~/]|~0|~1)*(?:/(?:[^~/]|~0|~1)*)*$"
    },
    "sourceSpan": {
      "type": "object",
      "required": [
        "source_document_id",
        "source_revision",
        "stable_span"
      ],
      "properties": {
        "source_document_id": {
          "$ref": "#/$defs/artifactId"
        },
        "source_revision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "stable_span": {
          "type": "object",
          "required": [
            "span_id"
          ],
          "properties": {
            "span_id": {
              "$ref": "#/$defs/artifactId"
            },
            "char_start": {
              "type": "integer",
              "minimum": 0
            },
            "char_end": {
              "type": "integer",
              "minimum": 1
            },
            "line_start": {
              "type": "integer",
              "minimum": 1
            },
            "line_end": {
              "type": "integer",
              "minimum": 1
            },
            "text_hash": {
              "$ref": "#/$defs/hash"
            }
          },
          "allOf": [
            {
              "if": {
                "required": [
                  "char_start"
                ]
              },
              "then": {
                "required": [
                  "char_end"
                ]
              }
            },
            {
              "if": {
                "required": [
                  "line_start"
                ]
              },
              "then": {
                "required": [
                  "line_end"
                ]
              }
            }
          ],
          "unevaluatedProperties": false
        },
        "source_hash": {
          "$ref": "#/$defs/hash"
        }
      },
      "unevaluatedProperties": false
    },
    "transformationType": {
      "type": "string",
      "enum": [
        "verbatim",
        "visualized",
        "compressed",
        "reordered",
        "inferred",
        "authorized_addition"
      ]
    },
    "provenanceEntry": {
      "type": "object",
      "required": [
        "provenance_id",
        "transformation_type",
        "derived_by_stage",
        "confidence"
      ],
      "properties": {
        "provenance_id": {
          "$ref": "#/$defs/artifactId"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceSpan"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "fact_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactId"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "transformation_type": {
          "$ref": "#/$defs/transformationType"
        },
        "authorization_id": {
          "$ref": "#/$defs/artifactId"
        },
        "derived_by_stage": {
          "$ref": "#/$defs/stageId"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "inference_note": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "note": {
          "type": "string",
          "maxLength": 1000
        }
      },
      "anyOf": [
        {
          "required": [
            "source_refs"
          ]
        },
        {
          "required": [
            "fact_ids"
          ]
        },
        {
          "required": [
            "authorization_id"
          ]
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "transformation_type": {
                "const": "authorized_addition"
              }
            },
            "required": [
              "transformation_type"
            ]
          },
          "then": {
            "required": [
              "authorization_id"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformation_type": {
                "const": "inferred"
              }
            },
            "required": [
              "transformation_type"
            ]
          },
          "then": {
            "required": [
              "inference_note"
            ]
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "fieldProvenance": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/jsonPointer"
      },
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/provenanceEntry"
        },
        "minItems": 1,
        "uniqueItems": true
      }
    }
  },
  "unevaluatedProperties": false
}
