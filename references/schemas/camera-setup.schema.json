{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.script-to-shootable-storyboard.invalid/v1/camera-setup.schema.json",
  "title": "Camera Setup",
  "description": "定义一个可执行且可复用的摄影机、镜头、对焦、灯光、轴线和混合制作交接配置。",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "created_by_stage",
    "source_hash",
    "camera_setup_id",
    "job_id",
    "scene_id",
    "blocking_plan_id",
    "coordinate_system_ref",
    "camera_position",
    "sensor_or_frame_basis",
    "focal_length",
    "field_of_view",
    "height",
    "orientation",
    "focus_strategy",
    "frame_rate",
    "shutter",
    "resolution",
    "color_space",
    "lighting_state",
    "axis_side",
    "supported_shot_intent_ids",
    "platform_constraints",
    "setup_cost",
    "field_provenance"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/semver"
    },
    "created_at": {
      "$ref": "#/$defs/dateTime"
    },
    "created_by_stage": {
      "$ref": "#/$defs/stageId"
    },
    "source_hash": {
      "$ref": "#/$defs/hash"
    },
    "camera_setup_id": {
      "$ref": "#/$defs/id"
    },
    "job_id": {
      "$ref": "#/$defs/id"
    },
    "scene_id": {
      "$ref": "#/$defs/id"
    },
    "blocking_plan_id": {
      "$ref": "#/$defs/id"
    },
    "coordinate_system_ref": {
      "$ref": "#/$defs/id"
    },
    "camera_position": {
      "$ref": "#/$defs/point"
    },
    "sensor_or_frame_basis": {
      "$ref": "#/$defs/sensorBasis"
    },
    "focal_length": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "等效或实际焦距，单位由 sensor_or_frame_basis 声明，默认毫米。"
    },
    "field_of_view": {
      "$ref": "#/$defs/fieldOfView"
    },
    "height": {
      "type": "number",
      "minimum": 0,
      "description": "相对于场景坐标系地面的相机高度。"
    },
    "orientation": {
      "$ref": "#/$defs/orientation"
    },
    "focus_strategy": {
      "type": "string",
      "enum": [
        "fixed_distance",
        "single_mark",
        "rack_focus",
        "continuous_subject_tracking",
        "deep_focus"
      ]
    },
    "focus_distance_or_marks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/focusMark"
      }
    },
    "frame_rate": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 240
    },
    "shutter": {
      "$ref": "#/$defs/shutter"
    },
    "resolution": {
      "$ref": "#/$defs/resolution"
    },
    "color_space": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "lighting_state": {
      "$ref": "#/$defs/lightingState"
    },
    "axis_side": {
      "type": "string",
      "enum": [
        "left",
        "right",
        "on_axis",
        "crossing_with_plan"
      ]
    },
    "axis_crossing_plan_id": {
      "$ref": "#/$defs/id"
    },
    "supported_shot_intent_ids": {
      "$ref": "#/$defs/idList"
    },
    "platform_constraints": {
      "$ref": "#/$defs/platformConstraints"
    },
    "setup_cost": {
      "$ref": "#/$defs/setupCost"
    },
    "hybrid_handoff": {
      "$ref": "#/$defs/hybridHandoff"
    },
    "field_provenance": {
      "$ref": "#/$defs/fieldProvenance"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "focus_strategy": {
            "enum": [
              "fixed_distance",
              "single_mark",
              "rack_focus",
              "continuous_subject_tracking"
            ]
          }
        },
        "required": [
          "focus_strategy"
        ]
      },
      "then": {
        "required": [
          "focus_distance_or_marks"
        ],
        "properties": {
          "focus_distance_or_marks": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "axis_side": {
            "const": "crossing_with_plan"
          }
        },
        "required": [
          "axis_side"
        ]
      },
      "then": {
        "required": [
          "axis_crossing_plan_id"
        ]
      }
    }
  ],
  "$defs": {
    "id": {
      "$ref": "provenance.schema.json#/$defs/artifactId"
    },
    "semver": {
      "$ref": "provenance.schema.json#/$defs/semver"
    },
    "dateTime": {
      "$ref": "provenance.schema.json#/$defs/dateTime"
    },
    "stageId": {
      "$ref": "provenance.schema.json#/$defs/stageId"
    },
    "hash": {
      "$ref": "provenance.schema.json#/$defs/hash"
    },
    "fieldProvenance": {
      "$ref": "provenance.schema.json#/$defs/fieldProvenance"
    },
    "idList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "point": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "unevaluatedProperties": false
    },
    "sensorBasis": {
      "type": "object",
      "required": [
        "basis_type",
        "width",
        "height",
        "unit"
      ],
      "properties": {
        "basis_type": {
          "type": "string",
          "enum": [
            "physical_sensor",
            "full_frame_equivalent",
            "virtual_camera"
          ]
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "millimeters",
            "virtual_units"
          ]
        },
        "crop_factor": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "unevaluatedProperties": false
    },
    "fieldOfView": {
      "type": "object",
      "required": [
        "horizontal_degrees",
        "vertical_degrees"
      ],
      "properties": {
        "horizontal_degrees": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 180
        },
        "vertical_degrees": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 180
        }
      },
      "unevaluatedProperties": false
    },
    "orientation": {
      "type": "object",
      "required": [
        "pan_degrees",
        "tilt_degrees",
        "roll_degrees"
      ],
      "properties": {
        "pan_degrees": {
          "type": "number",
          "minimum": -360,
          "maximum": 360
        },
        "tilt_degrees": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "roll_degrees": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "look_at_target_id": {
          "$ref": "#/$defs/id"
        }
      },
      "unevaluatedProperties": false
    },
    "focusMark": {
      "type": "object",
      "required": [
        "focus_mark_id",
        "sequence",
        "distance",
        "unit"
      ],
      "properties": {
        "focus_mark_id": {
          "$ref": "#/$defs/id"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "subject_id": {
          "$ref": "#/$defs/id"
        },
        "actor_mark_id": {
          "$ref": "#/$defs/id"
        },
        "distance": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "meters",
            "centimeters"
          ]
        },
        "action_phase_id": {
          "$ref": "#/$defs/id"
        }
      },
      "unevaluatedProperties": false
    },
    "shutter": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "angle",
            "seconds"
          ]
        },
        "angle_degrees": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 360
        },
        "exposure_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "angle"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "required": [
              "angle_degrees"
            ],
            "not": {
              "required": [
                "exposure_seconds"
              ]
            }
          },
          "else": {
            "required": [
              "exposure_seconds"
            ],
            "not": {
              "required": [
                "angle_degrees"
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "resolution": {
      "type": "object",
      "required": [
        "width",
        "height",
        "pixel_aspect_ratio"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "pixel_aspect_ratio": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "unevaluatedProperties": false
    },
    "lightingState": {
      "type": "object",
      "required": [
        "lighting_state_id",
        "description",
        "color_temperature_kelvin"
      ],
      "properties": {
        "lighting_state_id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        },
        "color_temperature_kelvin": {
          "type": "number",
          "minimum": 1000,
          "maximum": 20000
        },
        "key_direction_degrees": {
          "type": "number",
          "minimum": 0,
          "exclusiveMaximum": 360
        },
        "lighting_asset_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      },
      "unevaluatedProperties": false
    },
    "aspectRatio": {
      "type": "string",
      "pattern": "^[1-9][0-9]{0,3}:[1-9][0-9]{0,3}$"
    },
    "platformConstraints": {
      "type": "object",
      "required": [
        "platform_profile_id",
        "aspect_ratio",
        "safe_zone_id",
        "subtitle_zone_id",
        "ui_occlusion_zone_ids"
      ],
      "properties": {
        "platform_profile_id": {
          "$ref": "#/$defs/id"
        },
        "aspect_ratio": {
          "$ref": "#/$defs/aspectRatio"
        },
        "safe_zone_id": {
          "$ref": "#/$defs/id"
        },
        "subtitle_zone_id": {
          "$ref": "#/$defs/id"
        },
        "ui_occlusion_zone_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      },
      "unevaluatedProperties": false
    },
    "setupCost": {
      "type": "object",
      "required": [
        "changeover_minutes",
        "estimated_amount",
        "currency"
      ],
      "properties": {
        "changeover_minutes": {
          "type": "number",
          "minimum": 0
        },
        "estimated_amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "crew_or_compute_complexity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "specialist"
          ]
        }
      },
      "unevaluatedProperties": false
    },
    "hybridHandoff": {
      "type": "object",
      "required": [
        "tracking_data_required",
        "tracking_data_ids",
        "clean_plate_asset_ids",
        "mask_requirements",
        "lens_distortion_profile_required",
        "frame_rate_match_required",
        "color_space_match_required"
      ],
      "properties": {
        "tracking_data_required": {
          "type": "boolean"
        },
        "tracking_data_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "clean_plate_asset_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "mask_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "lens_distortion_profile_required": {
          "type": "boolean"
        },
        "lens_distortion_profile_id": {
          "$ref": "#/$defs/id"
        },
        "frame_rate_match_required": {
          "type": "boolean"
        },
        "color_space_match_required": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "tracking_data_required": {
                "const": true
              }
            },
            "required": [
              "tracking_data_required"
            ]
          },
          "then": {
            "properties": {
              "tracking_data_ids": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lens_distortion_profile_required": {
                "const": true
              }
            },
            "required": [
              "lens_distortion_profile_required"
            ]
          },
          "then": {
            "required": [
              "lens_distortion_profile_id"
            ]
          }
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "unevaluatedProperties": false
}
